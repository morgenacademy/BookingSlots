# Copy to apps/web/.env.local for local dev, and set in Netlify for prod.

# Supabase — local default values come from `supabase start`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Default studio (House of Eve seeded UUID)
NEXT_PUBLIC_DEFAULT_STUDIO_ID=00000000-0000-0000-0000-000000000001

# Site URL (for Mollie redirects + magic-link callback)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mollie — get a test key at https://my.mollie.com (test_xxx)
MOLLIE_API_KEY=test_xxx
